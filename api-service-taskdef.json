{
  "family": "api-service",
  "networkMode": "bridge",
  "requiresCompatibilities": [
    "EC2"
  ],
  "executionRoleArn": "arn:aws:iam::854727438903:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "854727438903.dkr.ecr.eu-north-1.amazonaws.com/petstore-api:latest",
      "cpu": 128,
      "memory": 128,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5001,
          "hostPort": 8081,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "CATALOG_URL",
          "value": "http://172.31.22.225:8080"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/api-service",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}